{{ ansible_managed | comment(beginning="##", end="##", decoration="#", prefix_count=0, postfix_count=0) }}

packages:
  cuda:
    require: '+allow-unsupported-compilers' 
    externals:
      - spec: cuda@12.4.1
        prefix: /nopt/nrel/apps/testing/eyas/cuda/12.4.1
    buildable: false
  slurm:
    buildable: false
    externals:
      - spec: slurm@25-05-5
        prefix: /nopt/slurm/current 
  libfabric:
    buildable: false
    externals:
      - spec: libfabric@1.22.0
        prefix: /opt/cray/libfabric/1.22.0 
  openmpi: 
    require:  '@5.0.3 schedulers=slurm fabrics=ofi'
  mpich: 
    require: +slurm 
  hwloc:
    require: '%gcc ^openmpi'
  intel-oneapi-mpi:
    require: '+external-libfabric%oneapi'
  boost:
    require: 'cxxflags="-pthread" ldflags="-pthread"'
  gtkplus:
    require: '@3.24.41'
  #hdf5:
  #  require: '%gcc'
  python:
    require: '%gcc'
  openbabel:
    require: '%gcc'
  #openbabel:
  #  require: 'cmake_args="-DENABLE_IPO=OFF"'
  #openblas:
  #  run_tests: false
  cray-mpich:
    require: "@8.1.32 %gcc"
    buildable: false
    externals:
      - spec: "cray-mpich@8.1.32%gcc"
        prefix: /opt/cray/pe/mpich/8.1.32/ofi/gnu/11.2
        modules:
          - cpe-stack
          - PrgEnv-gnu
          - libfabric
  all:
    buildable: true
    providers:
      blas: [openblas]
      lapack: [openblas]
      mpi: [openmpi,intel-oneapi-mpi,cray-mpich]
  gcc:
    externals:
    # System GCC
    - spec: gcc@11.4.1
      prefix: /usr
      extra_attributes:
        compilers:
          c: /usr/bin/gcc
          cxx: /usr/bin/g++
          fortran: /usr/bin/gfortran
      modules: []
    - spec: gcc@14.2.0
      prefix: /nopt/nrel/apps/testing/eyas/gcc/14.2.0
      extra_attributes:
        compilers:
          c: /nopt/nrel/apps/testing/eyas/gcc/14.2.0/bin/gcc
          cxx: /nopt/nrel/apps/testing/eyas/gcc/14.2.0/bin/g++
          fortran: /nopt/nrel/apps/testing/eyas/gcc/14.2.0/bin/gfortran
      modules: [gcc/14.2.0]
    - spec: gcc@=12.2.1
      prefix: /opt/rh/gcc-toolset-12
      extra_attributes:
        compilers:
          cc: /opt/rh/gcc-toolset-12/root/usr/bin/gcc
          cxx: /opt/rh/gcc-toolset-12/root/usr/bin/g++
          f77: /opt/rh/gcc-toolset-12/root/usr/bin/gfortran
          fc: /opt/rh/gcc-toolset-12/root/usr/bin/gfortran
      flags: {}
      operating_system: rhel9
      target: x86_64
      modules:
      - cpe-stack
      - PrgEnv-gnu
      environment: {}
      extra_rpaths: []
    - spec: gcc@13.2.1 languages:='c,c++,fortran'
      prefix: /opt/rh/gcc-toolset-13/root/usr
      extra_attributes:
        compilers:
          c: /opt/rh/gcc-toolset-13/root/usr/bin/gcc
          cxx: /opt/rh/gcc-toolset-13/root/usr/bin/g++
          fortran: /opt/rh/gcc-toolset-13/root/usr/bin/gfortran
      modules:
      - cpe-stack
      - PrgEnv-gnu
      environment: {}
      extra_rpaths: []
  # LLVM Compiler
  llvm:
    externals:
    - spec: llvm@19.1.0
      prefix: /nopt/nrel/apps/testing/eyas/llvm/19.1.0
      extra_attributes:
        compilers:
          c: /nopt/nrel/apps/testing/eyas/llvm/19.1.0/bin/clang
          cxx: /nopt/nrel/apps/testing/eyas/llvm/19.1.0/bin/clang++
          fortran: /nopt/nrel/apps/testing/eyas/gcc/14.2.0/bin/gfortran
      modules: [llvm/19.1.0]
  intel-oneapi-compilers:
    externals:
    - spec: intel-oneapi-compilers@2025.1.3
      prefix: /nopt/nrel/apps/testing/eyas/oneapi/2025.1.3/
      extra_attributes:
        compilers:
          c: /nopt/nrel/apps/testing/eyas/oneapi/2025.1.3/2025.1/bin/icx
          cxx: /nopt/nrel/apps/testing/eyas/oneapi/2025.1.3/2025.1/bin/icpx
          fortran: /nopt/nrel/apps/testing/eyas/oneapi/2025.1.3/2025.1/bin/ifx
